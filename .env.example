# ------------------------------------------------------------
# Is file ka naam ".env" rakho (copy karke) aur apni keys daalo
# ------------------------------------------------------------

# Prokerala Astrology API se milegi (https://api.prokerala.com)
# Free signup karke Client ID aur Client Secret milte hain
PROKERALA_CLIENT_ID=your_prokerala_client_id_here
PROKERALA_CLIENT_SECRET=your_prokerala_client_secret_here

# Anthropic (Claude) API key
# https://console.anthropic.com se milegi
ANTHROPIC_API_KEY=your_claude_api_key_here

# Server port
PORT=3000
